<?xml version="1.0" encoding="utf-8"?>
<!-- Splash screen shown while the Flutter engine starts (Android 5.0 - 11) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark green app background (AppTheme.backgroundGreen) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#062117" />
        </shape>
    </item>

    <!-- Logo, enlarged (artwork square matches the background color) -->
    <item
        android:width="220dp"
        android:height="220dp"
        android:gravity="center">
        <bitmap
            android:gravity="fill"
            android:src="@mipmap/ic_launcher_foreground" />
    </item>
</layer-list>
