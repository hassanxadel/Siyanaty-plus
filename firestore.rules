rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Siyanaty+ security rules
    //
    // Principle: a signed-in user may only touch documents that belong
    // to them. `request.auth != null` alone is NOT an authorization
    // check — any person who registers an account satisfies it — so
    // every rule below also verifies ownership via request.auth.uid.
    // ---------------------------------------------------------------

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // User profile. Contains PII and the trusted-device list that gates
    // MFA, so it must never be readable or writable by another account.
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // All per-user data lives under here: cars, reminders, maintenance,
      // mileage_entries, expenses, obd_scans, scans, devices,
      // favorite_service_centers, backups, ...
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Registration/authorization record, keyed by uid.
    match /authorized_users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // MFA codes. Only the owner may touch their own code document.
    // The document stores a hash of the code, never the code itself.
    match /mfa_codes/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Outbound mail queue consumed by the Firebase "Trigger Email"
    // extension. Clients enqueue messages but must never read the queue
    // (it contains other users' addresses and message bodies).
    match /mail/{mailId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Shared, read-only reference data maintained outside the app.
    match /service_centers/{centerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // NOTE: the previous ruleset also exposed top-level `cars`,
    // `maintenance_records`, `reminders`, `fuel_logs`, `obd_data` and
    // `app_settings` collections with `if request.auth != null`, i.e.
    // readable and writable by every registered user. No application
    // code references those paths (all data is stored under
    // users/{uid}/...), so they have been removed rather than scoped.

    // Anything not matched above is denied by default.
  }
}
